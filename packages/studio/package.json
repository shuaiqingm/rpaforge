{
  "name": "rpaforge-studio",
  "version": "0.3.3",
  "description": "RPAForge Studio - Visual RPA IDE built on Electron and React",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "i18n:extract": "i18next-scanner --config i18next-scanner.config.cjs"
  },
  "keywords": [
    "rpa",
    "automation",
    "robot-framework",
    "electron",
    "react"
  ],
  "author": "RPAForge Contributors",
  "license": "Apache-2.0",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@reactflow/background": "^11.3.14",
    "@reactflow/controls": "^11.2.14",
    "@reactflow/core": "^11.11.4",
    "@reactflow/minimap": "^11.7.14",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "chokidar": "^5.0.0",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^3.0.0",
    "immer": "^11.1.8",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.6.0",
    "react-syntax-highlighter": "^16.1.1",
    "sonner": "^2.0.7",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.2.5",
    "@tsconfig/svelte": "^5.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.12.3",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/ui": "^3.1.1",
    "ajv": "^8.18.0",
    "conventional-changelog-cli": "^5.0.0",
    "electron": "^42.1.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jest-environment-jsdom": "^29.5.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.5.2",
    "rollup": "^4.60.4",
    "sass": "^1.87.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.1.11",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.3",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "tar": ">=7.5.15",
    "dompurify": ">=3.4.1",
    "@tootallnate/once": ">=3.0.1"
  },
  "build": {
    "appId": "com.rpaforge.studio",
    "productName": "RPAForge Studio",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
