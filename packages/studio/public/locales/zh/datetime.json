{
  "library": "日期时间",
  "description": "日期和时间操作活动",
  "activities": {
    "get_current_date": {
      "name": "获取当前日期",
      "description": "获取当前日期",
      "output": "当前日期",
      "params": {
        "format": {
          "label": "格式",
          "description": "日期格式（默认为 YYYY-MM-DD）"
        }
      }
    },
    "get_current_time": {
      "name": "获取当前时间",
      "description": "获取当前时间",
      "output": "当前时间",
      "params": {
        "format": {
          "label": "格式",
          "description": "时间格式（默认为 HH:MM:SS）"
        }
      }
    },
    "get_current_datetime": {
      "name": "获取当前日期时间",
      "description": "获取当前日期和时间",
      "output": "当前日期时间",
      "params": {
        "format": {
          "label": "格式",
          "description": "日期时间格式（默认为 YYYY-MM-DD HH:MM:SS）"
        }
      }
    },
    "add_to_date": {
      "name": "日期加减",
      "description": "在日期上增加或减少时间",
      "output": "计算后的日期",
      "params": {
        "date": {
          "label": "日期",
          "description": "起始日期"
        },
        "value": {
          "label": "数值",
          "description": "要加减的数值"
        },
        "unit": {
          "label": "单位",
          "description": "时间单位（days、hours、minutes、seconds）"
        },
        "format": {
          "label": "格式",
          "description": "输出日期格式"
        }
      }
    },
    "date_difference": {
      "name": "日期差",
      "description": "计算两个日期之间的差异",
