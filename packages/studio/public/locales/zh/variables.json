    "convert_type": {
      "name": "类型转换",
      "description": "将变量转换为不同类型",
      "output": "转换后的值",
      "params": {
        "value": {
          "label": "值",
          "description": "要转换的值"
        },
        "type": {
          "label": "目标类型",
          "description": "目标类型（string、number、boolean）"
        }
      }
