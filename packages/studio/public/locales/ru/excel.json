{
  "library": "Excel",
  "description": "Операции с файлами Excel с использованием openpyxl",
  "activities": {
    "open_workbook": {
      "name": "Открыть книгу",
      "description": "Открыть существующий файл книги Excel",
      "output": "Путь к открытой рабочей книге",
      "params": {
        "path": {
          "label": "Путь",
          "description": "Путь к файлу Excel"
        },
        "read_only": {
          "label": "Только для чтения",
          "description": "Открыть книгу в режиме только для чтения"
        }
      }
    },
    "create_workbook": {
      "name": "Создать книгу",
      "description": "Создать новую пустую книгу Excel",
      "output": "Идентификатор новой рабочей книги"
    },
    "close_workbook": {
      "name": "Закрыть книгу",
      "description": "Закрыть текущую книгу, при необходимости сохранив изменения",
      "params": {
        "save": {
          "label": "Сохранить",
          "description": "Сохранить книгу перед закрытием"
        }
      }
    },
    "save_workbook": {
      "name": "Сохранить книгу",
      "description": "Сохранить книгу в файл",
      "output": "Путь к сохранённой рабочей книге",
      "params": {
        "path": {
          "label": "Путь",
          "description": "Путь для сохранения файла (необязательно, если уже открыт)"
        }
      }
    },
    "get_sheet_names": {
      "name": "Получить имена листов",
      "description": "Получить список всех имён листов в книге",
      "output": "Список имён листов"
    },
    "get_active_sheet": {
      "name": "Получить активный лист",
      "description": "Получить имя текущего активного листа",
      "output": "Имя активного листа"
    },
    "set_active_sheet": {
      "name": "Установить активный лист",
      "description": "Установить активный лист по имени",
      "params": {
        "sheet": {
          "label": "Лист",
          "description": "Имя листа для активации"
        }
      }
    },
    "create_sheet": {
      "name": "Создать лист",
      "description": "Создать новый лист в книге",
      "output": "Имя созданного листа",
      "params": {
        "name": {
          "label": "Имя",
          "description": "Имя для нового листа"
        }
      }
    },
    "delete_sheet": {
      "name": "Удалить лист",
      "description": "Удалить лист из книги",
      "params": {
        "name": {
          "label": "Имя",
          "description": "Имя листа для удаления"
        }
      }
    },
    "read_cell": {
      "name": "Прочитать ячейку",
      "description": "Прочитать значение из конкретной ячейки",
      "output": "Значение ячейки",
      "params": {
        "cell": {
          "label": "Ячейка",
          "description": "Адрес ячейки (например, A1)"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "write_cell": {
      "name": "Записать в ячейку",
      "description": "Записать значение в конкретную ячейку",
      "params": {
        "cell": {
          "label": "Ячейка",
          "description": "Адрес ячейки (например, A1)"
        },
        "value": {
          "label": "Значение",
          "description": "Значение для записи"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "read_range": {
      "name": "Прочитать диапазон",
      "description": "Прочитать диапазон ячеек, при необходимости как словари",
      "output": "Список строк (или список словарей)",
      "params": {
        "start_cell": {
          "label": "Начальная ячейка",
          "description": "Начальная ячейка диапазона (например, A1)"
        },
        "end_cell": {
          "label": "Конечная ячейка",
          "description": "Конечная ячейка диапазона (например, Z100)"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        },
        "as_dict": {
          "label": "Как словарь",
          "description": "Вернуть данные как список словарей с заголовками"
        }
      }
    },
    "write_range": {
      "name": "Записать диапазон",
      "description": "Записать двумерный массив данных начиная с ячейки",
      "params": {
        "data": {
          "label": "Данные",
          "description": "Двумерный массив значений для записи"
        },
        "start_cell": {
          "label": "Начальная ячейка",
          "description": "Ячейка для начала записи (например, A1)"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "find_row": {
      "name": "Найти строку",
      "description": "Найти строку по значению в столбце",
      "output": "Номер строки или None",
      "params": {
        "column": {
          "label": "Столбец",
          "description": "Номер столбца для поиска (начиная с 1)"
        },
        "value": {
          "label": "Значение",
          "description": "Искомое значение"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "get_row_count": {
      "name": "Получить количество строк",
      "description": "Получить количество строк на листе",
      "output": "Количество строк",
      "params": {
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "get_column_count": {
      "name": "Получить количество столбцов",
      "description": "Получить количество столбцов на листе",
      "output": "Количество столбцов",
      "params": {
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "insert_rows": {
      "name": "Вставить строки",
      "description": "Вставить пустые строки над указанной строкой",
      "params": {
        "row": {
          "label": "Строка",
          "description": "Номер строки для вставки (1-based)"
        },
        "count": {
          "label": "Количество",
          "description": "Количество строк для вставки"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "delete_rows": {
      "name": "Удалить строки",
      "description": "Удалить строки начиная с указанной",
      "params": {
        "row": {
          "label": "Строка",
          "description": "Начальный номер строки (1-based)"
        },
        "count": {
          "label": "Количество",
          "description": "Количество строк для удаления"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "insert_columns": {
      "name": "Вставить столбцы",
      "description": "Вставить пустые столбцы перед указанным",
      "params": {
        "col": {
          "label": "Столбец",
          "description": "Номер столбца для вставки (1-based)"
        },
        "count": {
          "label": "Количество",
          "description": "Количество столбцов для вставки"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "delete_columns": {
      "name": "Удалить столбцы",
      "description": "Удалить столбцы начиная с указанного",
      "params": {
        "col": {
          "label": "Столбец",
          "description": "Начальный номер столбца (1-based)"
        },
        "count": {
          "label": "Количество",
          "description": "Количество столбцов для удаления"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        }
      }
    },
    "read_sheet_to_list": {
      "name": "Прочитать лист в список",
      "description": "Прочитать весь лист в список словарей с использованием заголовков",
      "output": "Список словарей строк по заголовкам",
      "params": {
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        },
        "header": {
          "label": "Заголовок",
          "description": "Использовать первую строку как заголовки"
        }
      }
    },
    "write_list_to_sheet": {
      "name": "Записать список на лист",
      "description": "Записать список словарей на лист",
      "params": {
        "data": {
          "label": "Данные",
          "description": "Список словарей для записи"
        },
        "sheet": {
          "label": "Лист",
          "description": "Имя листа (активный лист, если не указан)"
        },
        "start_cell": {
          "label": "Начальная ячейка",
          "description": "Ячейка для начала записи (по умолчанию A1)"
        }
      }
    }
  }
}